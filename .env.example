# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only, never expose to client

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # restrict by HTTP referrer + required APIs only
GOOGLE_MAPS_SERVER_KEY=           # server-side geocoding (restrict by IP)

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5 # configurable per environment

# Email
RESEND_API_KEY=
NEWSLETTER_PROVIDER=convertkit    # convertkit | buttondown | mailchimp
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# App
NEXT_PUBLIC_SITE_URL=
REVALIDATE_SECRET=                # for on-demand ISR revalidation endpoint
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
